{
  "name": "seaxmusic",
  "version": "2.0.5",
  "description": "SeaxMusic",
  "changelog": {
    "2.0.5": [
      "🎨 Player bar rediseñado con estilo premium (glassmorphism, gradientes, animaciones)",
      "👤 Menú de perfil con diseño premium y animaciones",
      "🎠 Carrusel NowPlaying mejorado - imágenes laterales ahora usan misma resolución que la central",
      "⏮️ Botón anterior arreglado - fallback a seek(0) si no hay canción previa",
      "🔊 Volumen persiste correctamente al cambiar de canción",
      "🚪 Modal de logout rediseñado con estilo premium",
      "🔄 Sistema de auto-update mejorado en modo desarrollo",
      "📋 Cola de biblioteca tiene prioridad sobre sugerencias de YouTube",
      "🎵 Botón de lyrics funciona correctamente en NowPlaying"
    ]
  },
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl",
    "publish": "electron-builder --publish always",
    "publish:win": "electron-builder --win --publish always",
    "release": "electron-builder --publish always"
  },
  "keywords": [
    "music",
    "electron",
    "youtube",
    "player"
  ],
  "author": "SeaxMusic Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vyran1/SeaxMusicV2.git"
  },
  "build": {
    "appId": "com.seaxmusic.app",
    "productName": "SeaxMusic",
    "copyright": "Copyright © 2026 SeaxMusic Team",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/renderer/assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SeaxMusic"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "build/icon.ico",
      "category": "public.app-category.music"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "build/icon.ico",
      "category": "Audio"
    },
    "publish": {
      "provider": "github",
      "owner": "Vyran1",
      "repo": "SeaxMusicV2",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.4.0"
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.7.3"
  }
}
